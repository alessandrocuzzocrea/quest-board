  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n back,front -c cyan,green \"cd ../backend && cargo dev\" \"vite dev --host\"",
    "build": "npm run gen:types && vite build",
    "preview": "vite preview",
    "gen:types": "cd ../backend && TS_RS_EXPORT_DIR=../frontend/src/lib/types/bindings cargo test --lib -- --skip ai_tools 2>&1",
    "lint:openapi": "npx @redocly/cli lint --config ../.redocly.yaml ../openapi.yaml",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
